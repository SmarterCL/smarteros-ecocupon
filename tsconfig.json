{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/ddd": [
        "./src/index.ts"
      ],
      "@/domains": [
        "./src/domains/index.ts"
      ],
      "@/domains/*": [
        "./src/domains/*"
      ],
      "@/infrastructure": [
        "./src/infrastructure/index.ts"
      ],
      "@/infrastructure/*": [
        "./src/infrastructure/*"
      ],
      "@/application": [
        "./src/application/index.ts"
      ],
      "@/application/*": [
        "./src/application/*"
      ],
      "@/shared": [
        "./src/shared/index.ts"
      ],
      "@/shared/*": [
        "./src/shared/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
