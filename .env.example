# Supabase Configuration (Vault Managed)
# Never commit actual credentials - use Supabase Vault
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_from_vault
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_from_vault

# Database (Vault managed - for migrations only)
POSTGRES_DATABASE=postgres
POSTGRES_HOST=your_supabase_db_host
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_from_vault

# Connection strings (Vault managed)
DATABASE_URL=postgresql://postgres:password_from_vault@host:5432/postgres
DATABASE_URL_NON_POOLING=postgresql://postgres:password_from_vault@host:5432/postgres?sslmode=require
